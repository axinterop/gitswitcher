#!/bin/bash

# Configuration file
CONFIG_DIR="$HOME/.config/gitswitcher"
CONFIG_FILE="$CONFIG_DIR/profiles.conf"

mkdir -p "$CONFIG_DIR"

# Load existing profiles
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    # Create default config file if it doesn't exist
    echo "# Git Helper Profiles Configuration" > "$CONFIG_FILE"
    echo "# Format: declare -A PROFILE_X=([name]=\"...\" [email]=\"...\" [signingkey]=\"...\" [desc]=\"...\")" >> "$CONFIG_FILE"
fi

PROFILES=($(compgen -A variable | grep ^PROFILE_))

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color


# Function to save new profile to config file
save_new_profile() {
    local name=$1
    local email=$2
    local signingkey=$3
    local desc=$4

    # Find the next available profile number
    local profile_num=1
    while declare -p PROFILE_${profile_num} &>/dev/null; do
        ((profile_num++))
    done
    local profile_name="PROFILE_${profile_num}"

    # Add to config file
    echo "declare -A $profile_name=(" >> "$CONFIG_FILE"
    echo "    [name]=\"$name\"" >> "$CONFIG_FILE"
    echo "    [email]=\"$email\"" >> "$CONFIG_FILE"
    echo "    [signingkey]=\"$signingkey\"" >> "$CONFIG_FILE"
    echo "    [desc]=\"$desc\"" >> "$CONFIG_FILE"
    echo ")" >> "$CONFIG_FILE"

    echo -e "${GREEN}Profile saved as $profile_name in $CONFIG_FILE${NC}"
}

# Function to check if current directory is a git repository
is_git_repo() {
    if [ -d .git ] || git rev-parse --git-dir > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# Function to generate SSH key (silent version)
generate_ssh_key() {
    local name=$1
    local email=$2
    local default_path=~/.ssh/
    local default_key="githelper_git_signing_key_$(date +%s)"

    read -p "$(echo -e "${YELLOW}Enter filename for the new SSH key (${default_path})[${default_key}]:${NC} ")" key_filename

    if [ -z "$key_filename" ]; then
        key_filename="$default_key"
    fi

    # Ensure full path
    key_filename="${default_path}${key_filename}"

    echo -e "${CYAN}Generating new SSH key for signing...${NC}"
    # Generate key silently
    ssh-keygen -t ed25519 -C "$email" -f "$key_filename" -q -N "" >/dev/null 2>&1

    # Add to SSH agent
    eval "$(ssh-agent -s)" >/dev/null 2>&1
    ssh-add "$key_filename" >/dev/null 2>&1

    echo -e "\n${GREEN}SSH key generated and set for commit signing.${NC}"
    echo -e "${BLUE}Public key:${NC} ${key_filename}.pub"
    echo -e "${BLUE}Private key:${NC} $key_filename"
    echo -e "${YELLOW}Don't forget to add the public key to your GitHub/GitLab account!${NC}"
    echo "${key_filename}.pub"  # Return just the public key path
}

# Dynamic menu generation
show_menu() {
    printf "${PURPLE}%-4s %-25s %-30s %-30s${NC}\n" "No." "Name" "Email" "Description"
    for i in "${!PROFILES[@]}"; do
        declare -n profile=${PROFILES[$i]}
        printf "${GREEN}%-4s %-25s %-30s %-30s${NC}\n" \
            "$((i+1)))" \
            "${profile[name]}" \
            "${profile[email]}" \
            "${profile[desc]}"
    done
    printf "${CYAN}%-4s %-25s %-30s %-30s${NC}\n" "$(( ${#PROFILES[@]} + 1 )))" "New profile" "" ""
    printf "${RED}%-4s %-25s %-30s %-30s${NC}\n" "$(( ${#PROFILES[@]} + 2 )))" "Delete profile" "" ""
    echo "0)   Exit"
}

delete_profile() {
    echo -e "${RED}Select a profile to delete:${NC}"
    for i in "${!PROFILES[@]}"; do
        declare -n profile=${PROFILES[$i]}
        printf "${RED}%-4s %-25s %-30s %-30s${NC}\n" \
            "$((i+1)))" \
            "${profile[name]}" \
            "${profile[email]}" \
            "${profile[desc]}"
    done
    read -p "$(echo -e "${YELLOW}Enter the number of the profile to delete (or 0 to cancel):${NC} ")" del_choice

    if [[ "$del_choice" =~ ^[0-9]+$ ]] && (( del_choice >= 1 && del_choice <= ${#PROFILES[@]} )); then
        profile_var="${PROFILES[$((del_choice-1))]}"
        # Remove the profile from the config file
        # Remove the declare line and all lines until the closing parenthesis
        sed -i "/declare -A $profile_var=(/,/)/d" "$CONFIG_FILE"
        echo -e "${GREEN}Profile $profile_var deleted.${NC}"
    else
        echo -e "${YELLOW}Deletion cancelled.${NC}"
    fi
}


apply_profile() {
    local profile_name=$1
    declare -n profile=$profile_name

    git config user.name "${profile[name]}"
    git config user.email "${profile[email]}"

    # Handle signing key
    if [[ -n "${profile[signingkey]}" && -f "${profile[signingkey]/\~/$HOME}" ]]; then
        git config user.signingkey "${profile[signingkey]}"
        git config gpg.format ssh
        git config commit.gpgsign true
        echo -e "${GREEN}Commit signing enabled with existing key${NC}"
    elif [[ -n "${profile[signingkey]}" ]]; then
        read -p "$(echo -e "${YELLOW}Signing key not found. Generate new one? [y/N]:${NC} ")" generate_key
        if [[ "$generate_key" =~ ^[Yy] ]]; then
            key_path=$(generate_ssh_key "${profile[name]}" "${profile[email]}")
            # Update the profile with the new key path
            sed -i "s|\[signingkey\]=\".*\"|\[signingkey\]=\"$key_path\"|" "$CONFIG_FILE"
            git config gpg.format ssh
            git config user.signingkey "$key_path"
            git config commit.gpgsign true
        else
            git config --unset user.signingkey || true
            git config commit.gpgsign false
            echo -e "${YELLOW}Commit signing disabled${NC}"
        fi
    else
        git config --unset user.signingkey || true
        git config commit.gpgsign false
        echo -e "${YELLOW}No signing key configured for this profile${NC}"
    fi
}

# Main execution
if ! is_git_repo; then
    echo -e "${RED}Error: Current directory is not a git repository.${NC}"
    exit 1
fi

while true; do
    # Reload profiles
    # Unset all PROFILE_* variables
    for var in $(compgen -A variable | grep ^PROFILE_); do
        unset -v "$var"
    done
    # Source the config file to load current profiles
    source "$CONFIG_FILE"
    # Rebuild the PROFILES array
    PROFILES=($(compgen -A variable | grep ^PROFILE_))

    show_menu
    read -p "$(echo -e "${YELLOW}Your choice:${NC} ")" choice

    case $choice in
        0) exit 0 ;;
        $(( ${#PROFILES[@]} + 1 )) )  # New profile option
            read -p "$(echo -e "${YELLOW}Enter full name:${NC} ")" name
            read -p "$(echo -e "${YELLOW}Enter email:${NC} ")" email
            read -p "$(echo -e "${YELLOW}Enter description:${NC} ")" desc

            # Handle signing key
            signingkey=""
            read -p "$(echo -e "${YELLOW}Configure signing key? [y/N]:${NC} ")" configure_key
            if [[ "$configure_key" =~ ^[Yy] ]]; then
                key_path=$(generate_ssh_key "$name" "$email")
                signingkey="$key_path"
            fi

            save_new_profile "$name" "$email" "$signingkey" "$desc"
            ;;
        $(( ${#PROFILES[@]} + 2 )) )  # Delete profile option
            delete_profile
            ;;
        *)
            if (( choice >= 1 && choice <= ${#PROFILES[@]} )); then
                apply_profile "${PROFILES[$((choice-1))]}"
            else
                echo -e "${RED}Invalid choice. Try again.${NC}"
            fi
            ;;
    esac

    # Show current configuration
    echo -e "\n${PURPLE}Current git configuration:${NC}"
    echo -e "${BLUE}Name:${NC}    $(git config user.name)"
    echo -e "${BLUE}Email:${NC}   $(git config user.email)"
    echo -e "${BLUE}Signing:${NC} $(git config commit.gpgsign)"
    if git config commit.gpgsign | grep -q true; then
        echo -e "${BLUE}Key:${NC}     $(git config user.signingkey)"
    fi
done

